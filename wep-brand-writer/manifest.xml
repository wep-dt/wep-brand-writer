<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="MailApp">
  <Id>6c2e3a1f-8b9d-4e5c-a1b2-c3d4e5f6a9b7</Id>
  <Version>1.0.7.0</Version>
  <ProviderName>WEP</ProviderName>
  <DefaultLocale>it-IT</DefaultLocale>
  <DisplayName DefaultValue="WEP Brand Writer"/>
  <Description DefaultValue="Assistente scrittura WEP"/>
  
  <IconUrl DefaultValue="https://wep-dt.github.io/wep-brand-writer/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://wep-dt.github.io/wep-brand-writer/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://digitalsupport.wep.org"/>
  
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1" />
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://wep-dt.github.io/wep-brand-writer/taskpane.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteMailbox</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>
</OfficeApp>
